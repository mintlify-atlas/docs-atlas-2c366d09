  "keyFeatures": [
    "In-game configuration UI for managing consumables and categories",
    "Real-time buff monitoring with color-coded status borders",
    "Visual inventory tracking with current/required counts",
    "Click-to-use functionality for consumables from the tracker window",
    "Weapon enchant tracking for temporary enchantments",
    "Automatic data migration from legacy versions",
    "Organized categories with customizable display",
    "Smart confirmation dialogs to prevent buff overwrites"
  ],
  "publicApiSurface": [
    "/rcc - Toggle addon window",
    "/raidcheck - Alternative toggle command",
    "/consumables - Alternative toggle command",
    "RaidConsumableChecker:Initialize() - Core initialization",
    "RaidConsumableChecker:UpdateConsumables() - Update inventory counts",
    "RaidConsumableChecker:UpdateBuffs() - Update buff status",
    "RaidConsumableChecker:UseConsumable(itemData) - Use consumable item",
    "RaidConsumableChecker:HasBuff(buffName) - Check buff status",
    "RaidConsumableChecker:GetItemCount(itemName) - Get item count",
    "RaidConsumableCheckerDB - Saved variables database"
  ]
